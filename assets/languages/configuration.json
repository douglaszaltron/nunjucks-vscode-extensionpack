{
  "comments": {
    "blockComment": ["{#", "#}"],
    "lineComment": ["{#", "#}"]
  },
  "brackets": [["{%", "%}"], ["{{", "}}"], ["[", "]"], ["(", ")"]],
  "autoClosingPairs": [
    ["{%", "%}"],
    ["{{", "}}"],
    ["(", ")"],
    ["\"", "\""],
    { "open": "[", "close": "]", "notIn": ["string", "comment"] },
    { "open": "`", "close": "`", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "{#", "close": "#}", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "{%(-|\\s)*(if|elif|else|for|block|macro|filter|raw|verbatim|call|asyncEach|asyncAll)\\b",
    "decreaseIndentPattern": "{%(-|\\s)*(endif|elif|else|endfor|endblock|endmacro|endfilter|endraw|endverbatim|endcall|endeach|endall)\\b"
  }
}
