{
  "name": "nunjucks-vscode-extensionpack",
  "displayName": "Nunjucks Formatter",
  "description": "HTML formatter for Nunjucks templates with AlpineJS support",
  "version": "0.3.0",
  "author": "Douglas Zaltron",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/douglaszaltron/nunjucks-vscode-extensionpack"
  },
  "homepage": "https://github.com/douglaszaltron/nunjucks-vscode-extensionpack",
  "bugs": {
    "url": "https://github.com/douglaszaltron/nunjucks-vscode-extensionpack/issues"
  },
  "publisher": "douglaszaltron",
  "icon": "images/icon.png",
  "categories": [
    "Programming Languages",
    "Formatters",
    "Snippets"
  ],
  "keywords": [
    "nunjucks",
    "njk",
    "alpinejs",
    "html",
    "formatter"
  ],
  "engines": {
    "vscode": "^1.82.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "main": "./out/extension",
  "activationEvents": [
    "onLanguage:njk"
  ],
  "contributes": {
    "snippets": [
      {
        "language": "njk",
        "path": "./assets/snippets/snippets.json"
      }
    ],
    "languages": [
      {
        "id": "njk",
        "aliases": [
          "Nunjucks",
          "nunjucks",
          "njk"
        ],
        "extensions": [
          ".njk",
          ".nunjucks"
        ],
        "configuration": "./assets/languages/configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "njk",
        "scopeName": "text.html.njk",
        "path": "./assets/syntaxes/njk.json"
      }
    ],
    "configuration": {
      "title": "Nunjucks Formatter",
      "properties": {
        "nunjucksFormatter.preprocessNunjucks": {
          "type": "boolean",
          "default": true,
          "description": "Move Nunjucks block tags ({% if %}, {% for %}, {% block %}, etc.) onto their own lines before formatting."
        },
        "nunjucksFormatter.wrapAttributes": {
          "type": "string",
          "default": "force-expand-multiline",
          "enum": [
            "auto",
            "force",
            "force-aligned",
            "force-expand-multiline",
            "aligned-multiple",
            "preserve",
            "preserve-aligned"
          ],
          "description": "HTML attribute wrapping strategy. Each attribute is placed on its own line."
        },
        "nunjucksFormatter.wrapLineLength": {
          "type": "number",
          "default": 0,
          "description": "Maximum line length. 0 = unlimited."
        },
        "nunjucksFormatter.preserveNewlines": {
          "type": "boolean",
          "default": true,
          "description": "Preserve existing blank lines."
        },
        "nunjucksFormatter.maxPreserveNewlines": {
          "type": "number",
          "default": 1,
          "description": "Maximum number of consecutive blank lines to preserve."
        },
        "nunjucksFormatter.endWithNewline": {
          "type": "boolean",
          "default": true,
          "description": "Ensure file ends with a newline."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18 --sourcemap",
    "watch": "concurrently \"tsc --noEmit --watch -p ./\" \"esbuild src/extension.ts --bundle --watch --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18 --sourcemap\"",
    "test": "tsc -p ./ && mocha out/test/**/*.test.js",
    "lint": "eslint src/ --ext .ts",
    "build": "node scripts/package.js",
    "version": "changeset version",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('out',{recursive:true,force:true});fs.rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/js-beautify": "^1.14.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.82.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "mocha": "^11.7.6",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "js-beautify": "^1.15.4"
  }
}
