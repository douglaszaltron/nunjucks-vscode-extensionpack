{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2022",
        "outDir": "out",
        "lib": ["es2022"],
        "sourceMap": true,
        "rootDir": "src",
        "types": ["node", "mocha"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "exclude": [
        "node_modules"
    ]
}
